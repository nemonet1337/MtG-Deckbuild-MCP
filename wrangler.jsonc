{
  "name": "mtg-deckbuild-mcp",
  "main": "src/worker.ts",
  "compatibility_date": "2026-07-01",
  "compatibility_flags": ["nodejs_compat"],
  // Create with: npx wrangler kv namespace create DECKS
  // then replace the id below with the generated namespace id.
  "kv_namespaces": [
    { "binding": "DECKS", "id": "REPLACE_WITH_KV_NAMESPACE_ID" }
  ]
}
