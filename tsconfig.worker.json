{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["src/worker.ts", "src/server.ts", "src/config.ts", "src/services/**/*.ts", "src/types/**/*.ts"],
  "exclude": ["src/services/fileDeckStore.ts"]
}
