{
  "name": "mtg-deckbuild-mcp",
  "version": "1.1.0",
  "description": "Scryfallに接続してAIがMTGデッキビルドを行うMCPサーバー",
  "type": "module",
  "bin": {
    "mtg-deckbuild-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:worker": "wrangler dev",
    "start": "node dist/index.js",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "test": "npm run typecheck && npm run typecheck:worker"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nemonet1337/MtG-Deckbuild-MCP.git"
  },
  "keywords": [
    "mcp",
    "magic-the-gathering",
    "mtg",
    "scryfall",
    "deckbuilding"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nemonet1337/MtG-Deckbuild-MCP/issues"
  },
  "homepage": "https://github.com/nemonet1337/MtG-Deckbuild-MCP#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "agents": "^0.3.10",
    "ai": "^5.0.116",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260710.1",
    "@types/node": "^26.1.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.42.0"
  }
}
